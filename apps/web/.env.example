# Web frontend environment variables (Vite — baked at build time)
# Copy to apps/web/.env.local for dev, or set as Vercel env vars for prod

# Backend API URL (the VPS where the HyperFix API runs)
VITE_API_URL=http://localhost:1337

# This frontend's own public URL (used by OAuth callbacks and shareable links)
VITE_CLIENT_URL=http://localhost:5173

# Same as VITE_CLIENT_URL — used to generate links in emails/invitations created client-side
VITE_APP_URL=http://localhost:5173
